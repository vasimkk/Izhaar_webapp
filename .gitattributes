# Auto detect text files and perform LF normalization
* text=auto

# JS/JSX/TS/TSX files
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf

# CSS/HTML/JSON/MD
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Config files
*.env  text eol=lf
.env*  text eol=lf

# Binary files - no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.svg  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
